    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.57.0",
    "eslint-plugin-vue": "^10.8.0",
    "less": "^4.6.4",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "~6.0.2",
    "vite": "8.0.3",
    "vue-tsc": "^3.2.6"
  }
